{
  "name": "wechat-ilink-client",
  "version": "0.1.0",
  "description": "Standalone WeChat iLink bot protocol client",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "echo-bot": "tsx examples/echo-bot.ts",
    "check:examples": "tsc -p examples/tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0"
  },
  "optionalDependencies": {
    "qrcode-terminal": "^0.12.0"
  }
}
